# Leave empty in development to use Vite proxy to backend (same origin /api)
VITE_API_URL=

# Or set full API URL for production builds, e.g. https://api.yourschool.com
# VITE_API_URL=https://api.yourschool.com

# Firebase Web SDK (optional — enables Google sign-in + Firestore client listeners)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
