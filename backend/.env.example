PORT=5000
CLIENT_ORIGIN=http://localhost:5173

MONGODB_URI=mongodb://127.0.0.1:27017/school_saas

JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Razorpay (India) — leave empty to use dummy payment fallback
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Firebase Admin (service account) — optional but required for Firestore sync + Storage uploads
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Set to true only on trusted machines — creates demo class/subjects
ALLOW_SEED=false

# Optional seed credentials (see scripts/seed.js)
SEED_ADMIN_EMAIL=admin@school.edu
SEED_ADMIN_PASSWORD=Admin@12345
SEED_TEACHER_EMAIL=teacher@school.edu
SEED_TEACHER_PASSWORD=Teacher@123
SEED_STUDENT_EMAIL=student@school.edu
SEED_STUDENT_PASSWORD=Student@123
